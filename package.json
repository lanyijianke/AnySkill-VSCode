{
  "name": "anyskill",
  "displayName": "AnySkill",
  "description": "Manage AI agent skills, prompts and rules — load on demand via natural language or GUI. Works with Cursor, Claude Code, Antigravity, Copilot. Private GitHub-backed skill library with curated Skill Packs | AI 技能管理终端，自然语言 + GUI 双通道",
  "version": "0.6.6",
  "icon": "resources/anyskill-icon.png",
  "publisher": "anyskill",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "ai",
    "ai-skills",
    "ai-agent",
    "skill",
    "skills",
    "agent",
    "skill-management",
    "prompt-management",
    "cursor-rules",
    "claude-code",
    "copilot",
    "antigravity",
    "agent-skills",
    "agent-library",
    "skill-library",
    "skill-packs",
    "anyskill",
    "ai-prompt",
    "coding-assistant",
    "developer-tools",
    "rules",
    "rule"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lanyijianke/AnySkill"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "anyskill-sidebar",
          "title": "AnySkill",
          "icon": "resources/anyskill-icon.svg"
        }
      ]
    },
    "views": {
      "anyskill-sidebar": [
        {
          "id": "anyskillSkills",
          "name": "My Skills | 我的技能",
          "icon": "$(symbol-method)"
        },
        {
          "id": "anyskillPacks",
          "name": "Packs | 组合包",
          "icon": "$(package)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "anyskillSkills",
        "contents": "Welcome to AnySkill!\nYour personal AI skill library.\n[Initialize | 初始化配置](command:anyskill.init)\n[Import Skills | 导入已有技能](command:anyskill.importSkill)",
        "when": "!anyskill.configured"
      }
    ],
    "commands": [
      {
        "command": "anyskill.init",
        "title": "AnySkill: Initialize | 初始化配置",
        "icon": "$(gear)"
      },
      {
        "command": "anyskill.refreshSkills",
        "title": "AnySkill: Refresh Skills | 刷新技能",
        "icon": "$(refresh)"
      },
      {
        "command": "anyskill.loadSkill",
        "title": "AnySkill: Edit in Cloud | 云端编辑",
        "icon": "$(cloud)"
      },
      {
        "command": "anyskill.downloadSkill",
        "title": "AnySkill: Download Skill | 下载技能",
        "icon": "$(cloud-download)"
      },
      {
        "command": "anyskill.downloadCategory",
        "title": "AnySkill: Download Folder | 下载整个文件夹",
        "icon": "$(cloud-download)"
      },
      {
        "command": "anyskill.syncAll",
        "title": "AnySkill: Sync All | 同步全部",
        "icon": "$(sync)"
      },
      {
        "command": "anyskill.uploadSkill",
        "title": "AnySkill: Upload Skill | 上传技能",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "anyskill.deleteSkill",
        "title": "AnySkill: Delete Skill | 删除技能",
        "icon": "$(trash)"
      },
      {
        "command": "anyskill.viewSkillDetail",
        "title": "AnySkill: View Skill Detail | 查看详情",
        "icon": "$(open-preview)"
      },
      {
        "command": "anyskill.installPack",
        "title": "AnySkill: Install Pack | 安装组合包",
        "icon": "$(desktop-download)"
      },
      {
        "command": "anyskill.refreshPacks",
        "title": "AnySkill: Refresh Packs | 刷新组合包",
        "icon": "$(refresh)"
      },
      {
        "command": "anyskill.checkUpdate",
        "title": "AnySkill: Check Update | 检查更新",
        "icon": "$(arrow-up)"
      },
      {
        "command": "anyskill.importSkill",
        "title": "AnySkill: Import Skill | 导入技能",
        "icon": "$(file-add)"
      },
      {
        "command": "anyskill.welcome",
        "title": "AnySkill: Welcome | 欢迎页",
        "icon": "$(home)"
      },
      {
        "command": "anyskill.createFolder",
        "title": "AnySkill: Create Folder | 新建文件夹",
        "icon": "$(new-folder)"
      },
      {
        "command": "anyskill.deleteFolder",
        "title": "AnySkill: Delete Folder | 删除文件夹",
        "icon": "$(trash)"
      },
      {
        "command": "anyskill.moveSkill",
        "title": "AnySkill: Move Skill | 移动技能",
        "icon": "$(move)"
      },
      {
        "command": "anyskill.pushSkill",
        "title": "AnySkill: Push Skill to Cloud | 推送技能到云端",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "anyskill.pullSkill",
        "title": "AnySkill: Pull from Cloud | 从云端更新",
        "icon": "$(cloud-download)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "anyskill.refreshSkills",
          "when": "view == anyskillSkills",
          "group": "navigation"
        },
        {
          "command": "anyskill.uploadSkill",
          "when": "view == anyskillSkills",
          "group": "navigation"
        },
        {
          "command": "anyskill.importSkill",
          "when": "view == anyskillSkills",
          "group": "navigation"
        },
        {
          "command": "anyskill.syncAll",
          "when": "view == anyskillSkills",
          "group": "navigation"
        },
        {
          "command": "anyskill.refreshPacks",
          "when": "view == anyskillPacks",
          "group": "navigation"
        },
        {
          "command": "anyskill.createFolder",
          "when": "view == anyskillSkills",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "anyskill.viewSkillDetail",
          "when": "view == anyskillSkills && viewItem == skill",
          "group": "inline"
        },
        {
          "command": "anyskill.downloadSkill",
          "when": "view == anyskillSkills && viewItem == skill",
          "group": "1_actions@1"
        },
        {
          "command": "anyskill.loadSkill",
          "when": "view == anyskillSkills && viewItem == skill",
          "group": "1_actions@2"
        },
        {
          "command": "anyskill.deleteSkill",
          "when": "view == anyskillSkills && viewItem == skill",
          "group": "2_danger@1"
        },
        {
          "command": "anyskill.installPack",
          "when": "view == anyskillPacks && viewItem == pack",
          "group": "inline"
        },
        {
          "command": "anyskill.downloadSkill",
          "when": "view == anyskillPacks && viewItem == packSkill",
          "group": "inline"
        },
        {
          "command": "anyskill.moveSkill",
          "when": "view == anyskillSkills && viewItem == skill",
          "group": "1_actions@3"
        },
        {
          "command": "anyskill.downloadCategory",
          "when": "view == anyskillSkills && viewItem == category",
          "group": "inline"
        },
        {
          "command": "anyskill.deleteFolder",
          "when": "view == anyskillSkills && viewItem == category",
          "group": "inline"
        }
      ],
      "explorer/context": [
        {
          "command": "anyskill.pushSkill",
          "when": "resourceFilename == SKILL.md",
          "group": "anyskill@1"
        },
        {
          "command": "anyskill.pullSkill",
          "when": "resourceFilename == SKILL.md",
          "group": "anyskill@2"
        },
        {
          "command": "anyskill.pushSkill",
          "when": "explorerResourceIsFolder && resourcePath =~ /skills/",
          "group": "anyskill@1"
        },
        {
          "command": "anyskill.pullSkill",
          "when": "explorerResourceIsFolder && resourcePath =~ /skills/",
          "group": "anyskill@2"
        }
      ],
      "editor/title": [
        {
          "command": "anyskill.pushSkill",
          "when": "resourceFilename == SKILL.md",
          "group": "navigation"
        },
        {
          "command": "anyskill.pullSkill",
          "when": "resourceFilename == SKILL.md",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "AnySkill",
      "properties": {
        "anyskill.repo": {
          "type": "string",
          "default": "",
          "description": "GitHub skill repository (format: username/repo-name) | GitHub 技能仓库 (格式: 用户名/仓库名)"
        },
        "anyskill.branch": {
          "type": "string",
          "default": "main",
          "description": "Repository branch | 仓库分支"
        },
        "anyskill.localPath": {
          "type": "string",
          "default": "",
          "description": "Local clone path | 本地仓库克隆路径"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run compile -- --watch",
    "package": "npm run compile -- --minify",
    "vscode:prepublish": "npm run package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.44"
  }
}