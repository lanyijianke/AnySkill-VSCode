{
    "root": true,
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "project": "./tsconfig.json"
    },
    "plugins": [
        "@typescript-eslint"
    ],
    "extends": [
        "eslint:recommended"
    ],
    "env": {
        "node": true,
        "es2022": true
    },
    "rules": {
        "no-unused-vars": "off",
        "no-empty": "warn"
    },
    "ignorePatterns": [
        "dist/",
        "node_modules/"
    ]
}